<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutMessageRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="1dp">

    <LinearLayout
        android:id="@+id/layoutSenderInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="start"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtMsgSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtMsgOwnerBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_badge_owner"
            android:paddingHorizontal="6dp"
            android:paddingVertical="1dp"
            android:text="@string/owner_badge"
            android:textColor="@color/white"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtMsgContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:background="@drawable/bg_message_received"
        android:maxWidth="280dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:textColor="@color/text_main"
        android:textSize="15sp" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgMsgPhoto"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

    <TextView
        android:id="@+id/txtMsgTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:textColor="@color/text_secondary"
        android:textSize="10sp" />

</LinearLayout>
